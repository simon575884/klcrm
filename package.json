{
  "name": "kl-auto-repair-crm",
  "version": "1.0.0",
  "description": "K&L 24 Hour Mobile Tire & Roadside Service CRM",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "cd client && npm run dev",
    "setup": "npm install && cd client && npm install",
    "init-db": "node server/initDb.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.19.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
